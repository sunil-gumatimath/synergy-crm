# Dependency directories
node_modules/
jspm_packages/

# Bun artifacts
# bun.lock and bun.lockb SHOULD NOT be ignored as they are needed for frozen builds
# bun.lockb
# bun.lock

# Build outputs
dist/
dist-ssr/
build/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# Testing / coverage
coverage/
.eslintcache

# Editor directories and files
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Tooling / Agents
.agent/
.agents/
.collaborator/
.gemini/
.antigravity/
.cursor/
skills-lock.json

# Supabase CLI
supabase/.temp/
supabase/.branches/
supabase/.cache/

# Bun / Vite cache
.bun/
.vite/
node_modules/.vite/

# Accidental local home-dir mirror
~/
~/.bun/
~/.bun/install/cache/

# Local database dumps
*.sql.gz
*.dump

# Backend SQL snapshots/scripts (never commit SQL)
database/*.sql
supabase/**/*.sql
# We keep migrations but ignore specific snapshots if needed
!supabase/migrations/
!supabase/migrations/*.sql

# One-off dev/migration scripts
apply-sql.cjs
apply-sql-robust.cjs
verify-supabase.cjs
