# Supabase Configuration
# ⚠️ SECURITY WARNING: Never commit this file with actual credentials!
# Copy this file to .env.local and replace with your actual Supabase credentials
# Get them from: https://app.supabase.com/project/_/settings/api
#
# IMPORTANT: 
# - Use .env.local for local development (already in .gitignore)
# - Never commit .env or .env.local to version control
# - If credentials are exposed, revoke them immediately in Supabase dashboard
# - See SECURITY.md for credential rotation instructions

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Application URL (used for password reset redirect)
# Set this to your production domain in deployed environments.
# If unset, the app falls back to localhost origins for development.
# Example: https://synergy.yourdomain.com
VITE_APP_URL=
